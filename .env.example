# RAG-MedQA 环境变量示例
# 大多数配置在 conf/service_conf.yaml 中，以下为关键环境变量覆盖项

# ── 数据库 ───────────────────────────────────────────────────────────
# DB_TYPE=mysql

# ── 搜索引擎 ─────────────────────────────────────────────────────────
# DOC_ENGINE=elasticsearch

# ── 用户功能 ─────────────────────────────────────────────────────────
# REGISTER_ENABLED=1          # 0=关闭注册
# DISABLE_PASSWORD_LOGIN=false # true=仅允许 OAuth 登录

# ── 超时设置（LLM 响应可能较慢） ────────────────────────────────────
# QUART_RESPONSE_TIMEOUT=600
# QUART_BODY_TIMEOUT=600

# ── 文件上传限制 ─────────────────────────────────────────────────────
# MAX_CONTENT_LENGTH=134217728    # 128MB

# ── 沙盒执行器（可选） ──────────────────────────────────────────────
# SANDBOX_ENABLED=0
# SANDBOX_HOST=sandbox-executor-manager
