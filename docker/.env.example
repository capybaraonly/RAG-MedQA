# =============================================================
# RAG-MedQA Docker 环境变量配置
# 使用方法: cp docker/.env.example docker/.env 然后填写 API Key
# =============================================================

# ---- LLM API Keys ----
# 主力模型 DeepSeek
DEEPSEEK_API_KEY=

# 备选模型 Qwen（阿里云灵积）
QWEN_API_KEY=

# ---- 服务密码（生产环境请修改） ----
MYSQL_ROOT_PASSWORD=infini_rag_flow
REDIS_PASSWORD=infini_rag_flow
ES_PASSWORD=infini_rag_flow
MINIO_ROOT_USER=rag_flow
MINIO_ROOT_PASSWORD=infini_rag_flow

# ---- 端口映射（一般不用改） ----
# 后端 API
BACKEND_PORT=9380
# 管理端 API
ADMIN_PORT=9381
# 前端（开发模式）
FRONTEND_PORT=9222
# Web 入口（生产 nginx）
HTTP_PORT=80

# ---- 备选 LLM 路由（主力失败时自动切换到 Qwen）----
FALLBACK_LLM_FACTORY=Tongyi-Qianwen
FALLBACK_LLM_NAME=qwen-max

# ---- 文档引擎：elasticsearch 或 opensearch ----
DOC_ENGINE=elasticsearch

# ---- 数据库类型：mysql 或 postgres ----
DB_TYPE=mysql
